{
  "manifest_version": 3,
  "name": "Warehouse Spending Tracker",
  "version": "1.0.0",
  "description": "Track lifetime Costco spending, analyze purchase history, and export reports. Not affiliated with Costco Wholesale.",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": ["https://www.costco.com/*"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.costco.com/myaccount*"],
      "js": ["lib/constants.js", "content/scraper.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
